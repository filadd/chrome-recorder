# Dependencies
node_modules/

# Build output
dist/
api/.aws-sam/

# Environment / secrets. Per-mode files (.env.development / .env.production) are
# committed (non-secret URLs); the generic .env and any *.local override (below)
# stay local-only.
.env

# Extension signing key — pins the extension ID; the public half lives in
# manifest.config.ts, the private half must never be committed.
extension-key.pem

# Local overrides
*.local

# Logs
*.log
npm-debug.log*

# OS / editor noise
.DS_Store
Thumbs.db
