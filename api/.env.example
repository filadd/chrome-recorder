PORT=8787

# Comma-separated allowed origins (the extension's origin) for CORS.
ALLOWED_ORIGINS=chrome-extension://<EXTENSION_ID>

# The Filadd gateway base URL. The stand-in validates the extension's JWT and
# resolves the user's email by forwarding `Authorization` to GET /api/user/me/.
# Local stack (run via dockerfiles manage.sh) — adjust host/port to your setup.
GATEWAY_URL=http://localhost:8000

# The file-uploads-api base URL. The stand-in proxies the multipart upload here
# directly (file-uploads-api has no app-level auth — it's gateway-fronted in prod).
FILE_UPLOADS_API_URL=http://localhost:8001

# Where file-uploads-api lands the assembled recording. The Processing flow reads
# (and deletes) recordings from exactly here.
DESTINATION_BUCKET=filadd-chrome-recorder-prod
DESTINATION_PATH=projects

# ── Processing & Delivery (the post-upload n8n flows the stand-in rehearses) ──

# AWS region of the recordings bucket. Credentials come from the standard AWS
# provider chain (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / profile) — the
# stand-in needs list/head/presign/delete on DESTINATION_BUCKET.
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# transcript-api (diarized transcription via Deepgram). Local stack:
# http://transcript-api-service.docker — needs TRANSCRIPT_API_DEEPGRAM_API_KEY set
# on transcript-api itself (rotate the old key) and its Celery workers running.
TRANSCRIPT_API_URL=http://transcript-api-service.docker

# ai-conversations-api (Delivery context generation). The PROMPT_ID is a prompt
# configured there that turns "current context + named transcript" into the updated
# context; USER_ID attributes the conversation; API_KEY is optional (falls back to
# the service's default OpenAI key).
AI_CONVERSATIONS_API_URL=http://ai-conversations-api-service.docker
AI_CONVERSATIONS_PROMPT_ID=
AI_CONVERSATIONS_USER_ID=
AI_CONVERSATIONS_API_KEY=

# Notion internal-integration token. Share the integration with the Pitches DB and
# the four databases below, and enable "read user information including email" so
# `recorded_by` resolves to a Person.
NOTION_TOKEN=
NOTION_TRANSCRIPTIONS_DB=
NOTION_SEGMENTS_DB=
NOTION_SPEAKERS_DB=
NOTION_CONTEXTS_DB=
