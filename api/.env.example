PORT=8787

# Comma-separated allowed origins (the extension's origin) for CORS.
ALLOWED_ORIGINS=chrome-extension://<EXTENSION_ID>

# The Filadd gateway base URL. The stand-in validates the extension's JWT and
# resolves the user's email by forwarding `Authorization` to GET /api/user/me/.
# Local stack (run via dockerfiles manage.sh) — adjust host/port to your setup.
GATEWAY_URL=http://localhost:8000

# The file-uploads-api base URL. The stand-in proxies the multipart upload here
# directly (file-uploads-api has no app-level auth — it's gateway-fronted in prod).
FILE_UPLOADS_API_URL=http://localhost:8001

# Where file-uploads-api lands the assembled recording.
DESTINATION_BUCKET=filadd-chrome-recorder-prod
DESTINATION_PATH=projects
