PORT=8787

# Shared secret expected as "Authorization: Bearer <API_TOKEN>"
API_TOKEN=dev-token

# Comma-separated allowed origins (the extension's origin)
ALLOWED_ORIGINS=chrome-extension://<EXTENSION_ID>

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: point at an S3-compatible endpoint (e.g. MinIO) for local testing
# S3_ENDPOINT=http://localhost:9000

# Logical bucket ref -> real bucket. Audio is transient.
S3_BUCKET_PROJECT=

PRESIGN_EXPIRES_SECONDS=3600
