# Extension build-time config (Vite injects VITE_-prefixed vars at build).
#
# Per-mode files are committed and selected by the build command:
#   .env.development  → `npm run dev` (HMR) and `npm run build:dev`
#   .env.production   → `npm run build`
# For a personal override without touching the committed files, add a gitignored
# `.env.development.local` / `.env.production.local` (or `.env.local`, all modes).

# Base URL of the n8n stand-in (api/) / real n8n the extension uploads through.
VITE_API_BASE_URL=http://localhost:8787

# Origin to read the `auth._token.local` cookie from — the Filadd frontend you
# log into. Local testing: the localhost frontend. Leave blank to scan every
# host-permission origin for the cookie.
VITE_AUTH_COOKIE_URL=http://localhost:3000
